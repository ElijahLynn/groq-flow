# groq-flow config — copy to ~/.config/groq-flow/groq-flowrc and edit.
# Format is  key: value  (one per line). Lines starting with # are ignored.

# Groq STT model id. whisper-large-v3-turbo is fastest; whisper-large-v3 is
# slightly more accurate on long/noisy audio.
model: whisper-large-v3-turbo

# Input language as ISO-639-1 ("en", "es", "de", ...). Leave blank to auto-detect.
language: en

# Optional context words / spelling hints to improve accuracy on jargon.
# e.g. proper nouns, product names, acronyms you say often.
transcription-prompt: Hedera, Hiero, Hashgraph, Jenkins, Ansible, iDRAC, RHEL

# Clips whose average (RMS) level is below this (in dB) are treated as silence
# and skipped — this is what stops empty presses from hallucinating text.
# Make it more negative (e.g. -50) if quiet speech gets dropped.
silence-threshold: -45

# How the transcript reaches your cursor:
#   type  = simulate keystrokes (does not touch your clipboard)
#   paste = copy to clipboard then Cmd-V (faster for long text; restores clipboard after)
paste-mode: type

# Hard cap on a single recording in seconds (safety net).
max-record-seconds: 300

# On-screen recording indicator (Hammerspoon setup only).
# Color: red, orange, yellow, green, blue, purple, pink, white.
indicator-color: red
# Style: "meter" (animated level bars) or "orb" (pulsing 3D Grok orb).
indicator-style: meter
